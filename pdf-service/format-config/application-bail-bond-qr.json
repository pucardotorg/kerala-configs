{
  "key": "application-bail-bond-qr",
  "config": {
    "content": [
      {
        "table": {
          "widths": ["*"],
          "body": [
            [
              {
                "stack": [
                  {
                    "text": "{{courtComplex}}",
                    "style": "header"
                  },
                  {
                    "text": "Case No: {{caseNumber}}",
                    "style": "header",
                    "margin": [0, 5, 0, 0]
                  },
                  {
                    "text": "In the matter of: {{caseName}}",
                    "style": "header",
                    "margin": [0, 5, 0, 0]
                  },
                  {
                    "text": "Date: {{date}}",
                    "style": "header",
                    "margin": [0, 5, 0, 15]
                  },
                  {
                    "style": "table",
                    "table": {
                      "widths": ["30%", "70%"],
                      "body": [
                        "{{#complainantList}}",
                        [
                          {
                            "text": "Complainant {{index}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{name}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        [
                          {
                            "text": "Advocate(s)",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{listOfAdvocatesRepresenting}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        "{{/complainantList}}",
                        [
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [true, false, false, false]
                          },
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [false, false, true, false]
                          }
                        ],
                        "{{#accusedList}}",
                        [
                          {
                            "text": "Accused {{index}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{name}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        [
                          {
                            "text": "Advocate(s)",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{listOfAdvocatesRepresenting}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        "{{/accusedList}}",
                        [
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [true, false, false, false]
                          },
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [false, false, true, false]
                          }
                        ],
                        [
                          {
                            "text": "Offence",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "S.138 of the Negotiable Instruments Act, 1881",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ]
                      ]
                    }
                  },
                  {
                    "text": "{{applicationTitle}}",
                    "style": "applicationTitle"
                  },
                  {
                    "text": "Petitioner Name: {{petitionerName}}",
                    "style": "bodyText"
                  },
                  {
                    "text": "{{partyName}}, the {{partyType}}, represented through Advocate {{advocateName}}, hereby submits this application before this Honorable Court seeking grant of bail",
                    "style": "bodyText"
                  },
                  {
                    "text": "Reason for Bail:",
                    "style": "boldText"
                  },
                  {
                    "stack": "{{{reasonForApplication}}}",
                    "style": "bodyText"
                  },
                  {
                    "text": "List of Attached Documents:",
                    "style": "boldText"
                  },
                  {
                    "text": "The following documents are hereby submitted along with this bail application:",
                    "style": "listBodyText"
                  },
                  {
                    "ul": [
                      "{{#documentList}}",
                      {
                        "text": "{{documentType}}",
                        "style": "bodyText"
                      },
                      "{{/documentList}}"
                    ],
                    "style": "list"
                  },
                  {
                    "text": "The petitioner assures and undertakes to the Honorable Court that this request is made in good faith and that the applicant will abide by all conditions imposed by the Court. The applicant also undertakes to appear before the Court as and when required.",
                    "style": "bodyText"
                  },

                  {
                    "text": "Therefore, the petitioner humbly requests the Honorable Court to consider this application and grant bail on such terms and conditions as the Court may deem fit and proper.",
                    "style": "bodyText"
                  },
                  {
                    "stack": "{{{additionalComments}}}",
                    "style": "bodyText"
                  },
                  {
                    "text": "Dated this {{day}} day of {{month}}, {{year}}.",
                    "style": "date"
                  },
                  {
                    "text": "{{advocateSignature}}",
                    "style": "signature",
                    "margin": [0, 60, 0, 5]
                  },
                  {
                    "text": "Advocate for {{partyName}}",
                    "style": "signature"
                  }
                ],
                "alignment": "left",
                "margin": [0, 20, 0, 20]
              }
            ]
          ]
        },
        "layout": "noBorders"
      },
      {
        "style": "ws-head",
        "table": {
          "widths": ["*"],
          "body": [
            [
              {
                "image": "{{qrCodeImage}}",
                "width": 180,
                "height": 180,
                "style": "qr-code"
              }
            ]
          ]
        },
        "layout": "noBorders"
      }
    ],
    "styles": {
      "header": {
        "fontSize": 14,
        "bold": true,
        "alignment": "center",
        "margin": [0, 0, 0, 0]
      },
      "subHeader": {
        "fontSize": 14,
        "bold": true,
        "alignment": "center",
        "margin": [0, 0, 0, 0]
      },
      "applicationTitle": {
        "fontSize": 15,
        "bold": true,
        "alignment": "center",
        "margin": [0, 20, 0, 10]
      },
      "subTitle": {
        "fontSize": 12,
        "bold": true,
        "margin": [0, 10, 0, 0]
      },
      "date": {
        "fontSize": 12,
        "alignment": "right",
        "bold": true,
        "margin": [0, 0, 0, 10]
      },
      "subjectText": {
        "fontSize": 12,
        "bold": true,
        "margin": [0, 10, 0, 10]
      },
      "bodyText": {
        "fontSize": 11,
        "margin": [0, 10, 0, 10]
      },
      "listBodyText": {
        "fontSize": 11,
        "margin": [0, 0, 0, 0]
      },
      "reasonForApplication": {
        "fontSize": 11,
        "margin": [0, 15, 0, 10]
      },
      "additionalComments": {
        "fontSize": 11,
        "margin": [0, 10, 0, 10]
      },
      "signature": {
        "fontSize": 12,
        "alignment": "left",
        "margin": [0, 0, 0, 0]
      },
      "address": {
        "fontSize": 12,
        "alignment": "left",
        "margin": [0, -10, 0, 10]
      },
      "tableData": {
        "bold": true,
        "fontSize": 10,
        "color": "black"
      },
      "boldText": {
        "fontSize": 11,
        "bold": true,
        "margin": [15, 10, 0, 5]
      },
      "list": {
        "margin": [15, 0, 0, 5]
      },
      "listItem": {
        "fontSize": 11,
        "margin": [0, 5, 0, 5]
      },
      "table": {
        "fontSize": 13
      },
      "tableText": {
        "fontSize": 13,
        "margin": [2, 5, 2, 5]
      },
      "qr-code": {
        "color": "#000000",
        "alignment": "left",
        "margin": [0, 0, 0, 0]
      }
    }
  }
}
