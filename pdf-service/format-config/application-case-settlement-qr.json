{
  "key": "application-case-settlement-qr",
  "config": {
    "content": [
      {
        "table": {
          "widths": ["*"],
          "body": [
            [
              {
                "stack": [
                  {
                    "text": "{{courtComplex}}",
                    "style": "header"
                  },
                  {
                    "text": "Case No: {{caseNumber}}",
                    "style": "header",
                    "margin": [0, 5, 0, 0]
                  },
                  {
                    "text": "In the matter of: {{caseName}}",
                    "style": "header",
                    "margin": [0, 5, 0, 0]
                  },
                  {
                    "text": "Date: {{date}}",
                    "style": "header",
                    "margin": [0, 5, 0, 15]
                  },
                  {
                    "style": "table",
                    "table": {
                      "widths": ["30%", "70%"],
                      "body": [
                        "{{#complainantList}}",
                        [
                          {
                            "text": "Complainant {{index}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{name}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        [
                          {
                            "text": "Advocate(s)",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{listOfAdvocatesRepresenting}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        "{{/complainantList}}",
                        [
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [true, false, false, false]
                          },
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [false, false, true, false]
                          }
                        ],
                        "{{#accusedList}}",
                        [
                          {
                            "text": "Accused {{index}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{name}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        [
                          {
                            "text": "Advocate(s)",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "{{listOfAdvocatesRepresenting}}",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ],
                        "{{/accusedList}}",
                        [
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [true, false, false, false]
                          },
                          {
                            "text": "",
                            "style": "tableText",
                            "border": [false, false, true, false]
                          }
                        ],
                        [
                          {
                            "text": "Offence",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          },
                          {
                            "text": "S.138 of the Negotiable Instruments Act, 1881",
                            "style": "tableText",
                            "border": [true, true, true, true]
                          }
                        ]
                      ]
                    }
                  },
                  {
                    "text": "{{applicationTitle}}",
                    "style": "applicationTitle"
                  },
                  {
                    "text": "Petitioner Name: {{petitionerName}}",
                    "style": "bodyText"
                  },
                  {
                    "text": "{{partyName}}, the {{partyType}}, represented through Advocate {{advocateName}}, hereby submits this application before this Honorable Court to request approval of a settlement agreement reached between the parties.",
                    "style": "bodyText"
                  },
                  {
                    "text": "The parties have engaged in discussions and have reached a mutually agreeable settlement, which they believe serves the best interests of both parties and obviates the need for prolonged litigation. The settlement agreement was finalized on {{dateOfSettlementAggrement}}.",
                    "style": "bodyText"
                  },
                  {
                    "text": "The petitioner assures and undertakes to the Honorable Court that this application is made in good faith and will not prejudice the other party.",
                    "style": "bodyText"
                  },
                  {
                    "text": "Therefore, the petitioner humbly requests the Honorable Court to consider this application and dismiss the above mentioned case",
                    "style": "bodyText"
                  },
                  {
                    "stack": "{{{additionalComments}}}",
                    "style": "bodyText"
                  },
                  {
                    "text": "Dated this {{day}} day of {{month}} {{year}}",
                    "style": "date"
                  },
                  {
                    "text": "{{advocateSignature}}",
                    "style": "signature",
                    "margin": [0, 60, 0, 5]
                  },
                  {
                    "text": "Advocate for {{partyName}}",
                    "style": "signature"
                  }
                ],
                "alignment": "left",
                "margin": [0, 20, 0, 20]
              }
            ]
          ]
        },
        "layout": "noBorders"
      },
      {
        "style": "ws-head",
        "table": {
          "widths": ["*"],
          "body": [
            [
              {
                "image": "{{qrCodeImage}}",
                "width": 180,
                "height": 180,
                "style": "qr-code"
              }
            ]
          ]
        },
        "layout": "noBorders"
      }
    ],
    "styles": {
      "header": {
        "fontSize": 14,
        "bold": true,
        "alignment": "center",
        "margin": [0, 0, 0, 0]
      },
      "subHeader": {
        "fontSize": 14,
        "bold": true,
        "alignment": "center",
        "margin": [0, 0, 0, 0]
      },
      "applicationTitle": {
        "fontSize": 15,
        "bold": true,
        "alignment": "center",
        "margin": [0, 20, 0, 10]
      },
      "subTitle": {
        "fontSize": 12,
        "bold": true,
        "margin": [0, 10, 0, 0]
      },
      "date": {
        "fontSize": 12,
        "alignment": "right",
        "bold": true,
        "margin": [0, 0, 0, 10]
      },
      "subjectText": {
        "fontSize": 12,
        "bold": true,
        "margin": [0, 10, 0, 10]
      },
       "ponitwiseText": {
        "fontSize": 11,
        "alignment": "left",
        "margin": [15, 0, 0, 5]
      },
      "bodyText": {
        "fontSize": 11,
        "margin": [0, 10, 0, 10]
      },
      "additionalComments": {
        "fontSize": 11,
        "margin": [0, 10, 0, 10]
      },
      "signature": {
        "fontSize": 12,
        "alignment": "left",
        "margin": [0, 0, 0, 0]
      },
      "address": {
        "fontSize": 12,
        "alignment": "left",
        "margin": [0, -10, 0, 10]
      },
      "qr-code": {
        "color": "#000000",
        "alignment": "left",
        "margin": [0, 0, 0, 0]
      },
      "table": {
        "fontSize": 13
      },
      "tableText": {
        "fontSize": 13,
        "margin": [2, 5, 2, 5]
      }
    }
  }
}
